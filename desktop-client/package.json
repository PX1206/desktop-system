{
  "name": "desktop-sync-client",
  "version": "1.6.0",
  "description": "云同步桌面同步客户端",
  "author": "desktop-system",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build && cross-env ELECTRON_CUSTOM_DIR= npm_config_electron_customdir= CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "build:win": "vite build && cross-env ELECTRON_CUSTOM_DIR= npm_config_electron_customdir= CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:6173 && electron .\"",
    "electron:build": "vite build && cross-env ELECTRON_CUSTOM_DIR= npm_config_electron_customdir= CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chokidar": "^3.5.3",
    "electron-updater": "^6.1.7",
    "form-data": "^4.0.0",
    "semver": "~7.7.3",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.27.4",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^3.2.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "extends": "./electron-builder.config.js",
    "appId": "com.desktop.sync",
    "productName": "云同步",
    "electronDownload": {
      "mirror": "https://cdn.npmmirror.com/binaries/electron/"
    },
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "shortcutName": "云同步"
    }
  }
}
